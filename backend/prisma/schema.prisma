datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
generator client {
  provider = "prisma-client-js"
}
model WaterLog {
  id        Int      @id @default(autoincrement())
  userId    String
  date      String
  intakeMl  Int
  createdAt DateTime @default(now())

  @@unique([userId, date])
}
